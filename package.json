{
  "name": "nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/Jairwin-L/nextjs-starter-kit#readme",
  "bugs": {
    "url": "https://github.com/Jairwin-L/nextjs-starter-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jairwin-L/nextjs-starter-kit.git"
  },
  "funding": "https://github.com/sponsors/Jairwin-L",
  "author": {
    "name": "Jairwin",
    "email": "jairwin@jairwin.cc"
  },
  "scripts": {
    "dev": "next dev --port 8060",
    "build": "next build",
    "ci:eslint": "vp lint -f json src -o ./.ci/eslint.json",
    "lint": "vp lint . && stylelint --allow-empty-input \"**/*.{css,less,scss}\"",
    "lint:fix": "vp fmt . && vp lint --fix . && stylelint --allow-empty-input --fix \"**/*.{css,less,scss}\"",
    "prepare": "vp config",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "dotenv -e .env -- prisma db push",
    "prisma:studio": "dotenv -e .env -- prisma studio",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "start": "next start --port 8062",
    "start:test": "next start --port 8061",
    "start:dev": "next start --port 8060"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "alova": "^3.3.4",
    "antd": "^6.0.0",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^10.0.0",
    "prisma": "^7.8.0",
    "stylelint": "^16.24.0",
    "stylelint-config-ali": "^2.3.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-ali"
    ]
  },
  "engines": {
    "node": "22.x"
  },
  "cnpm": {
    "mode": "pnpm"
  },
  "npm": {
    "mode": "pnpm"
  },
  "yarn": {
    "mode": "pnpm"
  },
  "packageManager": "pnpm@11.6.0"
}
