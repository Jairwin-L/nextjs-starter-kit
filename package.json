{
  "name": "nextjs-blank-template",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/Jairwin-L/nextjs-blank-template#readme",
  "bugs": {
    "url": "https://github.com/Jairwin-L/nextjs-blank-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jairwin-L/nextjs-blank-template.git"
  },
  "funding": "https://github.com/sponsors/Jairwin-L",
  "author": {
    "name": "Jairwin",
    "email": "jairwin@jairwin.cn"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 8060",
    "build": "next build --turbopack",
    "ci:eslint": "eslint -f json src -o ./.ci/eslint.json",
    "lint": "eslint . && stylelint --allow-empty-input \"**/*.{css,less,scss}\"",
    "lint:fix": "prettier --write . && eslint --fix . && stylelint --allow-empty-input --fix \"**/*.{css,less,scss}\"",
    "prepare": "husky",
    "start": "next start --port 8062",
    "start:test": "cross-env NODE_ENV=test next start --port 8061",
    "start:dev": "cross-env NODE_ENV=development next start --port 8060"
  },
  "dependencies": {
    "alova": "^3.3.4",
    "next": "15.5.2",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-config-ali": "^16.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "prettier-config-ali": "^1.5.0",
    "stylelint": "^16.24.0",
    "stylelint-config-ali": "^2.3.0",
    "stylelint-prettier": "^5.0.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,vue}": "eslint --fix",
    "*.{css,less,scss}": "stylelint --fix",
    "*.{cjs,css,cts,html,js,json,jsx,less,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}": "prettier --write"
  },
  "prettier": "prettier-config-ali",
  "stylelint": {
    "extends": [
      "stylelint-config-ali",
      "stylelint-prettier/recommended"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "cnpm": {
    "mode": "pnpm"
  },
  "npm": {
    "mode": "pnpm"
  },
  "yarn": {
    "mode": "pnpm"
  }
}
