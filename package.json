{
  "name": "nextjs-blank-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/Jairwin-L/nextjs-blank-template#readme",
  "bugs": {
    "url": "https://github.com/Jairwin-L/nextjs-blank-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jairwin-L/nextjs-blank-template.git"
  },
  "funding": "https://github.com/sponsors/Jairwin-L",
  "author": {
    "name": "Jairwin",
    "email": "jairwin@jairwin.cc"
  },
  "scripts": {
    "dev": "next dev --port 8060",
    "build": "next build",
    "ci:eslint": "vp lint -f json src -o ./.ci/eslint.json",
    "lint": "vp lint . && stylelint --allow-empty-input \"**/*.{css,less,scss}\"",
    "lint:fix": "vp fmt . && vp lint --fix . && stylelint --allow-empty-input --fix \"**/*.{css,less,scss}\"",
    "prepare": "vp config",
    "start": "next start --port 8062",
    "start:test": "next start --port 8061",
    "start:dev": "next start --port 8060"
  },
  "dependencies": {
    "alova": "^3.3.4",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier-config-ali": "^1.5.0",
    "stylelint": "^16.24.0",
    "stylelint-config-ali": "^2.3.0",
    "stylelint-prettier": "^5.0.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-ali",
      "stylelint-prettier/recommended"
    ]
  },
  "engines": {
    "node": "22.x"
  },
  "cnpm": {
    "mode": "pnpm"
  },
  "npm": {
    "mode": "pnpm"
  },
  "yarn": {
    "mode": "pnpm"
  },
  "packageManager": "pnpm@11.6.0"
}
