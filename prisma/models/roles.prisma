model Roles {
  id               Int               @id @default(autoincrement())
  code             String            @unique
  name             String
  description      String?
  is_system        Boolean           @default(false)
  status           RoleStatus        @default(ENABLED)
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @db.Timestamptz(6)
  created_by       String?
  updated_by       String?
  created_by_user  Users?            @relation("RoleCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updated_by_user  Users?            @relation("RoleUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  role_permissions RolePermissions[]
  user_roles       UserRoles[]

  @@index([created_by])
  @@index([status])
  @@index([updated_by])
  @@map("roles")
}

model RolePermissions {
  id            Int         @id @default(autoincrement())
  role_id       Int
  permission_id Int
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  permission    Permissions @relation(fields: [permission_id], references: [id])
  role          Roles       @relation(fields: [role_id], references: [id])

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}
