model AiProviders {
  id         Int      @id @default(autoincrement())
  value      String   @unique
  label      String
  color      String
  enabled    Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("ai_providers")
}
