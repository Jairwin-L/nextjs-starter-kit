model Permissions {
  id               Int               @id @default(autoincrement())
  name             String
  code             String            @unique
  parent_id        Int?
  type             PermissionType
  description      String?
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @db.Timestamptz(6)
  parent           Permissions?      @relation("PermissionToPermission", fields: [parent_id], references: [id])
  children         Permissions[]     @relation("PermissionToPermission")
  role_permissions RolePermissions[]

  @@map("permissions")
}
